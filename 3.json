    "id": "string-beans-ginger",
    "title": "String Beans with Fresh Ginger (Pad Puk King)",
    "description": "Spicy hot vegetarian dish made with fresh string beans, lemongrass, and coconut milk.",
    "servings": "3-4",
    "ingredients": [
      { "name": "fresh string beans", "amount": "1/2", "unit": "pound", "notes": "cut into 2-inch strips" },
